# /etc/udev/rules.d/99-x3-devices.rules
# X3 巡逻小车 - KERNELS 物理端口绑定 (比 ID_PATH 更短更稳)
# 廉价 CH340 无唯一序列号, by-id 重复 → 只能用物理端口

# STM32 底盘控制板 (BAT=11.6V) - Bus3 Port1 Port3
KERNELS=="3-1.3*", SUBSYSTEM=="tty", SYMLINK+="myserial", MODE="0666"

# 语音识别模块 - Bus1 Port2
KERNELS=="1-2*", SUBSYSTEM=="tty", SYMLINK+="myspeech", MODE="0666"

# 激光雷达 YDLIDAR X4 (CP2102) - Bus3 Port1 Port2
KERNELS=="3-1.2*", SUBSYSTEM=="tty", SYMLINK+="rplidar", MODE="0666"
